[Unit]
Description=FX AutoBuy Background Worker
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/fxautobuy
EnvironmentFile=/opt/fxautobuy/.env
ExecStart=/usr/bin/python3 scripts/background_worker.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
